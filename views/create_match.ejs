<h2>Создать матч</h2>
<% if (locals.error) { %>
    <p class="error"><%= error %></p>
<% } %>
<form method="post">
    <div>
        <label>Команда 1:</label>
        <select name="team1Id" required>
            <option value="">-- выберите --</option>
            <% teams.forEach(team => { %>
            <option value="<%= team.id %>"><%= team.name %></option>
            <% }) %>
        </select>
    </div>
    <div>
        <label>Счет команды 1:</label>
        <input type="number" name="team1Score" required min="0">
    </div>
    <div>
        <label>Команда 2:</label>
        <select name="team2Id" required>
            <option value="">-- выберите --</option>
            <% teams.forEach(team => { %>
            <option value="<%= team.id %>"><%= team.name %></option>
            <% }) %>
        </select>
    </div>
    <div>
        <label>Счет команды 2:</label>
        <input type="number" name="team2Score" required min="0">
    </div>
    <div>
        <label>Дата (если не указать, будет сейчас):</label>
        <input type="datetime-local" name="date">
    </div>
    <button type="submit">Создать матч</button>
</form>