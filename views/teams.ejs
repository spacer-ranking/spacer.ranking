<h2>Все команды</h2>
<div class="teams-grid">
    <% teams.forEach(team => { %>
    <div class="team-card">
        <div class="team-avatar">
            <% if (team.avatar) { %>
                <img src="<%= team.avatar %>" alt="<%= team.name %>">
            <% } else { %>
                <div class="no-avatar"></div>
            <% } %>
        </div>
        <h3><a href="/teams/<%= team.id %>"><%= team.name %></a></h3>
        <p>Рейтинг: <%= team.rating %></p>
        <p>Создатель: <%= team.creator ? team.creator.username : 'неизвестно' %></p>
    </div>
    <% }) %>
</div>