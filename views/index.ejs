<h2>Рейтинг команд</h2>
<table class="rating-table">
    <thead>
        <tr>
            <th>#</th>
            <th>Логотип</th>
            <th>Команда</th>
            <th>Рейтинг</th>
        </tr>
    </thead>
    <tbody>
        <% teams.forEach((team, index) => { %>
        <tr>
            <td><%= index+1 %></td>
            <td>
                <% if (team.avatar) { %>
                    <img src="<%= team.avatar %>" alt="<%= team.name %>" class="team-avatar">
                <% } else { %>
                    <div class="no-avatar"></div>
                <% } %>
            </td>
            <td><a href="/teams/<%= team.id %>"><%= team.name %></a></td>
            <td><%= team.rating %></td>
        </tr>
        <% }) %>
    </tbody>
</table>

<% if (user && user.role === 'leader') { %>
<div style="margin-top: 20px;">
    <a href="/teams/create" class="btn">Создать команду</a>
    <a href="/matches/create" class="btn">Создать матч</a>
</div>
<% } %>